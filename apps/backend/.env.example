# ============================================
# Hello Wiki Backend - 环境变量示例
# ============================================
# 说明：复制本文件为 .env 并根据实际环境修改

# 基础配置
PROJECT_NAME=Hello Wiki Backend
DEBUG=True
LOG_LEVEL=INFO
LOG_TO_FILE=True
LOG_FILE_PATH=./data/logs/backend.log
HOST=0.0.0.0
PORT=8000
WORKERS_COUNT=4

# 可观测性配置
OBSERVABILITY_ENABLED=True
OTEL_ENABLED=True
OTEL_SERVICE_NAME=hello-wiki-backend
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=
OTEL_INSTRUMENT_FASTAPI=True
OTEL_INSTRUMENT_LLAMAINDEX=True

# 数据库与缓存
DATABASE_URL=postgresql+asyncpg://postgres:vibe_coding@localhost:5432/zhiyuan
REDIS_URL=redis://localhost:6379/0

# LLM 配置 (DeepSeek 默认)
LLM_API_KEY=your-deepseek-api-key-here
LLM_BASE_URL=https://api.deepseek.com/v1

# 存储路径
STORAGE_BASE_PATH=./data
